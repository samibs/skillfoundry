    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "diff": "^7.0.0",
    "glob": "^13.0.6",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "^15.0.7",
    "marked-terminal": "^7.3.0",
    "openai": "^6.22.0",
    "react": "^18.3.1",
    "strip-ansi": "^7.1.0"
