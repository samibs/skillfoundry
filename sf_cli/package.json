{
  "name": "@skillfoundry/cli",
  "version": "2.0.62",
  "description": "SkillFoundry interactive CLI — AI-assisted development with governance",
  "type": "module",
  "bin": {
    "sf": "./bin/sf.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
