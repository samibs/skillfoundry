# Knowledge Sync Configuration
# Copy this file to knowledge-sync.conf and fill in your values.
#
# KNOWLEDGE_REPO_URL: Your GitHub knowledge repository (create a private repo)
#   Example: https://github.com/your-username/dev-memory.git
#
# KNOWLEDGE_REPO_LOCAL: Local clone path (auto-set by knowledge-sync.sh init)
# PROJECT_NAME: Auto-detected from directory name
#
KNOWLEDGE_REPO_URL=https://github.com/your-username/dev-memory.git
KNOWLEDGE_REPO_LOCAL=
PROJECT_NAME=
LAST_SYNC=
SYNC_COUNT=0
