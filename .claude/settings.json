      "Bash(git rebase *)",
      "Bash(git worktree *)",
      "Bash(git rev-parse *)",
      "Bash(git show *)",
      "Bash(git ls-files*)",
      "Bash(git remote *)",

      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(tree *)",
      "Bash(tree)",
      "Bash(wc *)",
      "Bash(du *)",
      "Bash(date *)",
      "Bash(date)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(command -v *)",
