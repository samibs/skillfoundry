      "Bash(source *)",
      "Bash(. *)",
      "Bash(export *)",
      "Bash(set *)",
      "Bash(echo *)",
      "Bash(printf *)",
      "Bash(test *)",
      "Bash([ *)",

      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh api *)",
      "Bash(gh repo *)",

      "Task"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME)",
      "Bash(rm -rf $HOME/*)",
      "Bash(mkfs*)",
      "Bash(dd if=*)",
      "Bash(:(){ :|:& };:)",
      "Bash(> /dev/sda*)",
      "Bash(chmod 777 /)",
      "Bash(chmod -R 777 /)",
      "Bash(sudo rm -rf *)",
      "Bash(wget * | bash)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(git push --force origin main)",
      "Bash(git push --force origin master)",
      "Bash(git push -f origin main)",
      "Bash(git push -f origin master)",
      "Bash(git reset --hard origin/*)",
      "Bash(git clean -fdx)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/validate-bash.sh"
          }
        ]
      }
    ]
  }
